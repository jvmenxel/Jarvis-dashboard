# Copy to .env and fill in the values you need.
# Everything is optional except DATABASE_URL. The app runs locally without
# Clerk or any AI provider keys — those unlock real auth and assistant replies.

# --- Database ---
# Postgres via the Neon serverless driver. Works for Neon (https://neon.tech)
# and Vercel Postgres (Neon under the hood). Get a free connection string at
# https://console.neon.tech/app/projects → use the "pooled connection" URL.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xyz.neon.tech/neondb?sslmode=require"

# --- Clerk auth (https://dashboard.clerk.com) ---
# Leave blank to run in local dev-mode (single fallback user, no sign-in).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# --- AI providers (all optional) ---
# If none are set, the assistant falls back to a deterministic local responder.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# --- Token-efficiency guards ---
AI_DEFAULT_PROVIDER="anthropic"       # "anthropic" | "openai" | "local"
AI_DEFAULT_MODEL="claude-haiku-4-5"   # small/cheap default; escalate per-request
AI_MAX_HISTORY_MESSAGES="8"           # rolling window size sent to the model
AI_MAX_MEMORY_ITEMS="4"               # top-k memory retrieval per request

# --- Daily briefing ingest ---
# Slack pull: user token with "im:history,channels:history,groups:history"
SLACK_USER_TOKEN=""
# Channel or DM id to read (e.g. D0ASXK77QCR for a bot DM)
SLACK_BRIEFING_CHANNEL=""
# Shared secret for POSTs to /api/briefings/webhook (used by Zapier / Cowork)
BRIEFING_WEBHOOK_SECRET=""
# Shared secret Vercel Cron must present to trigger the daily Slack pull
CRON_SECRET=""
